{
  "name": "@zl-ui/components",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles/components.css",
    "./button": {
      "import": "./dist/button.js",
      "default": "./dist/button.js"
    },
    "./message": {
      "import": "./dist/message.js",
      "default": "./dist/message.js"
    },
    "./upload": {
      "import": "./dist/upload.js",
      "default": "./dist/upload.js"
    },
    "./autocomplete": {
      "import": "./dist/autocomplete.js",
      "default": "./dist/autocomplete.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@zl-ui/utils": "workspace:*",
    "@zl-ui/theme": "workspace:*",
    "@vueuse/core": "^11.0.0"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.1.8",
    "vue": "^3.5.25",
    "vue-tsc": "^3.1.5"
  }
}
